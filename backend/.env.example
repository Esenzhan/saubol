# PostgreSQL (Neon или любой другой Postgres)
DATABASE_URL=postgres://user:password@host:5432/healthapp

# Секрет для подписи JWT
JWT_SECRET=change_me_to_a_long_random_string

# Ключ Anthropic API для AI-чата по документам
ANTHROPIC_API_KEY=sk-ant-...

# Порт сервера
PORT=4000

# Разрешённый origin фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173
